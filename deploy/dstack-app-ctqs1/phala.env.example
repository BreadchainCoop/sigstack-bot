# Copy to phala.env and fill in. Used by: phala deploy -e phala.env
# DO NOT commit phala.env (secrets).

# --- Your Docker images (build & push linux/amd64 first) ---
SIGNAL_BOT_IMAGE=YOUR_DOCKERHUB/signal-bot-tee:latest
SIGNAL_PROXY_IMAGE=YOUR_DOCKERHUB/signal-registration-proxy:latest
WHISPER_IMAGE=YOUR_DOCKERHUB/signal-whisper-api:latest

# --- Secrets ---
NEAR_AI_API_KEY=sk-...
TOOLS_WEB_SEARCH_API_KEY=

# --- Optional overrides ---
NEAR_AI_BASE_URL=https://cloud-api.near.ai/v1
NEAR_AI_MODEL=deepseek-ai/DeepSeek-V4-Flash
NEAR_AI_TIMEOUT=120s
WHISPER_ENABLED=true
WHISPER_MODEL=small
WHISPER_TIMEOUT=120s
TRANSLATE_ALL_ENABLED=true
CONVERSATION_MAX_MESSAGES=50
CONVERSATION_TTL=24h
LOG_LEVEL=debug
TOOLS_ENABLED=true
BOT_GITHUB_REPO=https://github.com/BreadchainCoop/sigstack-bot

# Private registry (only if images are not public):
# DSTACK_DOCKER_USERNAME=...
# DSTACK_DOCKER_PASSWORD=...
